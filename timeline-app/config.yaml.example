environment: dev

server:
  host: "127.0.0.1"
  port: 8100

ai:
  ollama_base_url: "http://127.0.0.1:11434"
  ollama_model: "qwen2.5:7b"
  timeout_seconds: 60

workspace:
  default_path: ""
  wsl_mode: true
  dirs:
    daily: "daily"
    articles: "articles"

lifelog:
  root_dir: "lifelog-system"
  config_path: "lifelog-system/config/config.yaml"
  privacy_config_path: "lifelog-system/config/privacy.yaml"
  db_path: "lifelog-system/data/lifelog.db"
  info_db_path: "lifelog-system/data/ai_secretary.db"
  activity_sync_seconds: 15
  browser_import_seconds: 3600
  info_config_dir: "lifelog-system/config/info_collector"
  info_collect_seconds: 3600
  info_limit: 10
